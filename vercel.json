{
    "version": 2,
    "builds": [
      {
        "src": "proj/wsgi.py",
        "use": "@vercel/python",
        "config": { "maxLambdaSize": "15mb", "runtime": "python3.11" }
      }
    ],
    "routes": [
      {
        "src": "/(.*)",
        "dest": "proj/wsgi.py"
      }
    ],
    "env": {
      "DJANGO_SETTINGS_MODULE": "proj.settings"
    }
  }